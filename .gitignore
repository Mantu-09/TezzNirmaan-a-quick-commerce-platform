# ============================================================
# TezzNirmaan — Root .gitignore
# SECURITY: Any file containing real credentials must be listed here.
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/

# ── Environment files — NEVER commit any .env with real values ──
# All variants are blocked. Only .env.example (placeholder values) is allowed.
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
**/.env
**/.env.local
**/.env.*
!**/.env.example

# ── Secrets / credentials — belt-and-suspenders block ────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.json
credentials.json
service-account*.json
firebase-adminsdk*.json

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
.next/
out/
.output/

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/

# ── OS / Editor files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Test coverage ─────────────────────────────────────────────
coverage/
.nyc_output/
jest_html_reporters_attach/

# ── Render / Deployment ───────────────────────────────────────
.render-buildinfo.json
