# TezzNirmaan Dashboard — Environment Variables
# Copy to .env.local and fill in your values. NEVER commit .env.local.

# Backend API (used server-side in rewrites)
API_BASE_URL=https://tezznirmaan-api.onrender.com

# Supabase (for realtime — client-safe anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public Razorpay key (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
