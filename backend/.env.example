# ======================
# Server
# ======================
PORT=3000
NODE_ENV=development

# ======================
# Supabase
# ======================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# B7: DB Connection Pooling
# For direct Postgres queries (pg package), always use the POOLER URL
# (Transaction mode, port 6543) NOT the direct URL (port 5432).
# Find in: Supabase Dashboard → Project Settings → Database → Connection Pooling
# SUPABASE_DB_POOLER_URL=postgresql://postgres.xxx:DB_PASS@aws-x.pooler.supabase.com:6543/postgres
# SUPABASE_DB_DIRECT_URL=postgresql://postgres.xxx:DB_PASS@db.xxx.supabase.co:5432/postgres

# ======================
# Auth / JWT
# ======================
JWT_SECRET=your-jwt-secret

# ======================
# Razorpay
# ======================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ======================
# CORS
# ======================
CORS_ORIGIN=http://localhost:3000

# ======================
# SMS — Fast2SMS (B1)
# Get your key: https://www.fast2sms.com/dashboard/api-credentials
# Free tier: 500 SMS on signup. No DLT needed for transactional route.
# Leave blank to disable SMS (notifications still work via in-app Realtime).
# ======================
FAST2SMS_API_KEY=

# ======================
# Redis — Upstash (B7)
# Free tier: 10,000 commands/day, 256MB, works from Render.
# Setup: https://console.upstash.com → Create database → REST API tab
# Leave BLANK in development — the app uses an in-memory mock automatically.
# ======================
UPSTASH_REDIS_REST_URL=https://YOUR_DB_NAME.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REST_TOKEN
