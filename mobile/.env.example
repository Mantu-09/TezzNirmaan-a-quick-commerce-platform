# TezzNirmaan Mobile App — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Backend API
EXPO_PUBLIC_API_BASE_URL=https://tezznirmaan-api.onrender.com/api/v1

# Supabase (for Realtime subscriptions only — regular data goes through backend API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Razorpay (public key only — secret key is NEVER in the mobile app)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
